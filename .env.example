# Шаблон для .env. Реальный .env создаётся автоматически в setup.sh — НЕ заполнять руками.
# Этот файл коммитится в репозиторий, .env — нет.

# Панель 3X-UI
XUI_USERNAME=admin
XUI_PASSWORD=GENERATED_BY_SETUP
XUI_WEB_BASE_PATH=/GENERATED_BY_SETUP/
XUI_PANEL_PORT=2053

# VLESS+Reality
VLESS_PORT=8443
REALITY_DEST=www.bing.com:443
REALITY_SERVER_NAME=www.bing.com
REALITY_PRIVATE_KEY=GENERATED_BY_SETUP
REALITY_PUBLIC_KEY=GENERATED_BY_SETUP
REALITY_SHORT_ID=GENERATED_BY_SETUP

# Первый клиент (создаётся в setup.sh)
FIRST_CLIENT_NAME=admin
FIRST_CLIENT_UUID=GENERATED_BY_SETUP

# ID inbound'а в БД 3X-UI (заполняется setup.sh после создания inbound; нужен helper-скриптам)
INBOUND_ID=GENERATED_BY_SETUP
